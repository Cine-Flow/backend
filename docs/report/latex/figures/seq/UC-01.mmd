%%{init: {"theme":"default"}}%%
sequenceDiagram
    actor U as Người dùng
    participant RA as RegisterActivity
    participant API as AuthController
    participant SVC as AuthService
    participant DB as PostgreSQL

    U->>RA: Nhập username, email, password
    RA->>API: POST /auth/register
    API->>SVC: register(request)
    SVC->>DB: Tìm email/username trùng
    DB-->>SVC: Không trùng
    SVC->>SVC: BCrypt.hash(password)
    SVC->>DB: INSERT users
    DB-->>SVC: OK
    SVC-->>API: User created
    API-->>RA: 200 ApiResponse OK
    RA-->>U: Chuyển sang LoginActivity
